# NFG platform (shared chat, link, presence, live status) — same port as Crash
VITE_NFG_API_BASE=http://127.0.0.1:3847

# Hangman game WebSocket (proxied through platform when using one domain)
VITE_HANGMAN_WS_PATH=/hangman/ws

# Production example (single public host):
# VITE_NFG_API_BASE=https://y666suf.com
# VITE_HANGMAN_WS_PATH=/hangman/ws
