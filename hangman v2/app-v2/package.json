{
  "name": "hangman-v2-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:ui\" \"npm:dev:electron\"",
    "dev:ui": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "electron": "electron .",
    "build": "vite build",
    "preview": "vite preview --port 5173",
    "dist:electron": "npm run build && electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^33.2.1",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
